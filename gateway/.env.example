# OpenClaw Fintech — Environment Variables
# Copy to .env and fill in your values

# === LLM Providers ===
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx  # optional fallback

# === Messaging Channels ===
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxx
WHATSAPP_TOKEN=EAAxxxxx
WHATSAPP_PHONE_ID=123456789
SLACK_BOT_TOKEN=xoxb-xxxxx
SLACK_APP_TOKEN=xapp-xxxxx
DISCORD_BOT_TOKEN=xxxxx

# === Exchange APIs ===
BINANCE_API_KEY=xxxxx
BINANCE_API_SECRET=xxxxx
COINBASE_API_KEY=xxxxx
COINBASE_API_SECRET=xxxxx
COINBASE_PASSPHRASE=xxxxx

# === DeFi ===
INFURA_PROJECT_ID=xxxxx
ALCHEMY_API_KEY=xxxxx
WALLET_ADDRESS=0xxxxx
# NEVER put private keys here — use a hardware wallet or vault
METAMASK_SNAP_ID=xxxxx

# === Financial Data ===
ALPHA_VANTAGE_API_KEY=xxxxx
COINGECKO_API_KEY=xxxxx
POLYGON_IO_API_KEY=xxxxx

# === Banking / Accounting ===
PLAID_CLIENT_ID=xxxxx
PLAID_SECRET=xxxxx
PLAID_ENV=sandbox  # sandbox | development | production

# === Legal / Compliance ===
SEC_EDGAR_USER_AGENT="YourCompany admin@yourcompany.com"
VIRUSTOTAL_API_KEY=xxxxx

# === Storage ===
AUDIT_LOG_PATH=./logs/audit.jsonl
DATA_ENCRYPTION_KEY=xxxxx  # for encrypting sensitive local data
